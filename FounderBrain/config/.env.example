# Copy to .env and fill in. Never commit .env.

# YouTube
YOUTUBE_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Embeddings (set one)
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3

# LLM for briefs
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Search / scrape
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Macro / market
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc

# Podcasts
LISTEN_NOTES_API_KEY=
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# Brief schedule
BRIEF_TIMEZONE=America/New_York
BRIEF_PUBLISH_LOCAL_TIME=06:30

# Logging
LOG_LEVEL=INFO
